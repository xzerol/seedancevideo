DATABASE_URL="file:/data/seedance.db"

# Volcengine Ark / Seedance
ARK_API_KEY=""
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
SEEDANCE_MODEL="doubao-seedance-2-0-260128"
SEEDREAM_MODEL="doubao-seedream-5-0-260128"

# Alibaba Cloud Model Studio / DashScope / Bailian video
DASHSCOPE_API_KEY=""
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/api/v1"
HAPPYHORSE_T2V_MODEL="happyhorse-1.0-t2v"
HAPPYHORSE_I2V_MODEL="happyhorse-1.0-i2v"
HAPPYHORSE_R2V_MODEL="happyhorse-1.0-r2v"
HAPPYHORSE_VIDEO_EDIT_MODEL="happyhorse-1.0-video-edit"
WAN_I2V_MODEL="wan2.7-i2v"

# S3/TOS compatible object storage. Uploaded assets must be reachable by Ark.
# For Volcengine TOS this can be omitted; the app derives it from S3_REGION as
# https://tos-s3-${S3_REGION}.volces.com. You may still override it here.
S3_ENDPOINT=""
S3_REGION="cn-beijing"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="false"
S3_PUBLIC_BASE_URL=""
ASSET_URL_TTL_SECONDS="86400"
MAX_UPLOAD_MB="80"

# Optional aliases also supported by the backend:
# TOS_ENDPOINT=""
# TOS_REGION="cn-beijing"
# TOS_BUCKET=""
# TOS_ACCESS_KEY_ID=""
# TOS_SECRET_ACCESS_KEY=""

# Completed video results are downloaded here for local archive/playback.
LOCAL_VIDEO_DIR="/app/generated-videos"
LOCAL_VIDEO_PUBLIC_BASE_URL="/api/local-files/videos"

# UI-only estimate shown beside the submit button.
NEXT_PUBLIC_TOKEN_PRICE_LABEL="0.046 元/千 tokens"
